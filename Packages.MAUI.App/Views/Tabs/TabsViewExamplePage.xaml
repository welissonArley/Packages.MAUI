<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModel="clr-namespace:Packages.MAUI.App.ViewModels.Tabs"
             x:DataType="viewModel:TabsViewExampleViewModel"
             x:Class="Packages.MAUI.App.Views.Tabs.TabsViewExamplePage">
    <VerticalStackLayout Spacing="30">
        <Label Margin="0,20,0,0" Text="In this example, each tab will have a different style. Select one option below:" FontSize="16"/>
        <Button Text="Rounded Tab Style" Command="{Binding RoundedStyleCommand}"/>
        <Button Text="Underlined Tab Style" Command="{Binding UnderlinedStyleCommand}"/>
    </VerticalStackLayout>
</ContentPage>